        "note": "主业与中收",
        "weight": 0.24,
        "metrics": [
          { "key": "coreRevenueGrowth", "direction": "higherBetter" },
          { "key": "feeAssetRatio", "direction": "higherBetter" },
          { "key": "trueCoreNonInterest", "direction": "higherBetter" },
          { "key": "volatileIncomeShare", "direction": "lowerBetter" },
          { "key": "cashProfitRatio", "direction": "higherBetter" }
        ],
        "actionTitle": "先修主业造血",
        "action": "把核心营收、真实核心非息和手续费资产比作为价值质量第一层验证，围绕客户经营、结算沉淀、财富管理和场景服务建立中收修复清单。"
      },
