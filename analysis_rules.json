  "vqaEngine": {
    "version": "v0.2",
    "scoreBands": [
      { "min": 72, "label": "价值质量具备主动沟通基础" },
      { "min": 58, "label": "价值质量处于结构修复区间" },
      { "min": 0, "label": "价值质量仍需先修复经营底盘" }
    ],
    "dimensions": {
      "profit": {
        "label": "盈利真实性",
        "note": "主业与中收",
        "weight": 0.24,
        "metrics": [
          { "key": "coreRevenueGrowth", "direction": "higherBetter" },
          { "key": "feeAssetRatio", "direction": "higherBetter" },
          { "key": "trueCoreNonInterest", "direction": "higherBetter" },
          { "key": "volatileIncomeShare", "direction": "lowerBetter" },
          { "key": "cashProfitRatio", "direction": "higherBetter" }
        ],
        "actionTitle": "先修主业造血",
        "action": "把核心营收、真实核心非息和手续费资产比作为价值质量第一层验证，围绕客户经营、结算沉淀、财富管理和场景服务建立中收修复清单。"
      },
      "nim": {
        "label": "息差防守",
        "note": "资产负债对冲",
        "weight": 0.22,
        "metrics": [
          { "key": "nim", "direction": "higherBetter" },
          { "key": "nimGapBp", "direction": "lowerBetter" },
          { "key": "realLoanDepositSpread", "direction": "higherBetter" },
          { "key": "timeDepositShare", "direction": "lowerBetter" },
          { "key": "corporateDemandDepositShare", "direction": "higherBetter" }
        ],
        "actionTitle": "先修资产负债底盘",
        "action": "建立息差对冲缺口月度看板，拆解资产收益率变化和负债成本变化，优先压降高成本定期负债并提升结算沉淀。"
      },
      "risk": {
        "label": "风险确认",
        "note": "偏离与隐性暴露",
        "weight": 0.22,
        "metrics": [
          { "key": "npl", "direction": "lowerBetter" },
          { "key": "hiddenNplExposure", "direction": "lowerBetter" },
          { "key": "overdueNplDeviation", "direction": "lowerBetter" },
          { "key": "provisionCoverage", "direction": "higherBetter" },
          { "key": "retailRiskMax", "direction": "lowerBetter" }
        ],
        "actionTitle": "风险确认前移",
        "action": "把逾期账龄、五级分类、零售分产品不良和拨备节奏合并进同一预警框架，避免利润改善掩盖风险滞后确认。"
      },
      "capital": {
        "label": "资本效率",
        "note": "RWA与资本余量",
        "weight": 0.2,
        "metrics": [
          { "key": "cet1Buffer", "direction": "higherBetter" },
          { "key": "carBuffer", "direction": "higherBetter" },
          { "key": "rwaDensity", "direction": "lowerBetter" },
          { "key": "rwaProfitGrowthGap", "direction": "lowerBetter" },
          { "key": "roa", "direction": "higherBetter" }
        ],
        "actionTitle": "资本回报纪律",
        "action": "把新增资产投放与RWA消耗、风险调整回报和资本余量挂钩，避免扩表继续消耗战略自由度。"
      },
      "valuation": {
        "label": "估值验证",
        "note": "PB与质量匹配",
        "weight": 0.12,
        "metrics": [
          { "key": "pb", "direction": "higherBetter" },
          { "key": "roa", "direction": "higherBetter" },
          { "key": "coreRevenueGrowth", "direction": "higherBetter" },
          { "key": "hiddenNplExposure", "direction": "lowerBetter" }
        ],
        "actionTitle": "估值叙事重构",
        "action": "先用经营质量证明低估值是价值错配，而不是质量折价，再进入资本市场沟通。"
      }
    }
  },
  "valuationAssumptions": {
    "defaultCoe": 10,
    "terminalGrowth": 3,
    "expectedLossRate": 0.6,
    "coeByBankType": {
      "国有大行": 8.5,
      "股份行": 10,
      "城市商业银行": 11,
      "农村商业银行": 12
    },
    "sensitivityStep": 1,
    "caveat": "以下归因基于截面回归和公开年报数据，反映市场定价的统计规律，不等同于因果承诺。"
  },
  "warningRules": {
    "red": {
      "trigger": "anyTwo",
      "conditions": [
        "coreRevenueGrowth < peerAvg.coreRevenueGrowth and coreRevenueGrowth < 0",
        "nim < peerAvg.nim and interestLiabilityCost > peerAvg.interestLiabilityCost",
        "overdueNplDeviation > 1.2 and overdueNplDeviation > peerAvg.overdueNplDeviation",
        "hiddenNplExposure > peerAvg.hiddenNplExposure and overdueNplDeviation > 1",
        "volatileIncomeShare > peerAvg.volatileIncomeShare and coreRevenueGrowth < peerAvg.coreRevenueGrowth",
        "liquidityCoverageRatio < peerAvg.liquidityCoverageRatio and liquidityCoverageRatio < 120",
        "provisionCoverage < peerAvg.provisionCoverage and provisionCoverageChange < 0",
        "cet1Buffer < 150",
        "rwaDensity > peerAvg.rwaDensity and roa < peerAvg.roa",
        "pb < peerAvg.pb and roa < peerAvg.roa and coreRevenueGrowth < peerAvg.coreRevenueGrowth"
      ],
      "message": "目标银行当前不宜直接形成估值修复叙事，应优先解释经营质量、风险确认和资本消耗压力。"
    },
    "yellow": {
      "trigger": "anyTwo",
      "conditions": [
        "coreRevenueGrowth > 0 and coreRevenueGrowth < peerAvg.coreRevenueGrowth",
        "feeAssetRatio < peerAvg.feeAssetRatio",
        "trueCoreNonInterest < peerAvg.trueCoreNonInterest and volatileIncomeShare > peerAvg.volatileIncomeShare",
        "nim >= peerAvg.nim * 0.95 and interestLiabilityCost > peerAvg.interestLiabilityCost",
        "liquidityCoverageRatio < peerAvg.liquidityCoverageRatio",
        "overdueNplDeviation > 1 and provisionCoverage > peerAvg.provisionCoverage",
        "pb < peerAvg.pb and partialQualityBetterThanPeer"
      ],
      "message": "目标银行存在结构性改善空间，建议围绕收入结构、负债成本和风险确认节奏形成专项管理动作。"
    },
    "green": {
      "trigger": "anyThree",
      "conditions": [
        "roa > peerAvg.roa",
        "coreRevenueGrowth > peerAvg.coreRevenueGrowth",
        "feeAssetRatio > peerAvg.feeAssetRatio",
        "trueCoreNonInterest > peerAvg.trueCoreNonInterest and volatileIncomeShare <= peerAvg.volatileIncomeShare",
        "nim > peerAvg.nim or interestLiabilityCost < peerAvg.interestLiabilityCost",
        "overdueNplDeviation < peerAvg.overdueNplDeviation",
        "provisionCoverage > peerAvg.provisionCoverage",
        "cet1Buffer > 300"
      ],
      "message": "目标银行具备较好的经营质量基础，可进一步围绕资本效率、轻资本收入和市场定价开展价值重估沟通。"
    }
  },
